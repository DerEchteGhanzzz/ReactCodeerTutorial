{
  "name": "my-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start": "vite dev",
    "mock": "npx tsx ./api-mock",
    "prebuild": "npm run lint && tsc -b",
    "build": "vite build",
    "preview": "vite preview --port 3000 --strictPort",
    "lint": "eslint ./src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint ./src --fix --ext ts,tsx",
    "test": "vitest --ui --api 9527 --coverage --coverage.reportOnFailure --config ./vite.config.ts",
    "test:watch": "vitest --watch --ui --api 9527 --coverage --coverage.reportOnFailure --config ./vite.config.ts",
    "test:report": "vitest run --coverage --reporter=junit --reporter=verbose --outputFile=report.xml --config ./vite.config.ts",
    "format": "prettier --write ./src",
    "test:browser": "vitest --workspace=vitest.workspace.ts",
    "deps": "depcruise src",
    "postinstall": "npx playwright-chromium install"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "styled-components": "^6.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.1"
  }
}
